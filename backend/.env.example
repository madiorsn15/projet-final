# ══════════════════════════════════════════════
# VARIABLES D'ENVIRONNEMENT — SunuMarché Backend
# Copier ce fichier en .env et remplir les valeurs
# Ne JAMAIS committer le fichier .env sur Git !
# ══════════════════════════════════════════════

PORT=5000
NODE_ENV=development

# MongoDB local :
MONGO_URI=mongodb://localhost:27017/marketplace
# MongoDB Atlas (prod) :
# MONGO_URI=mongodb+srv://<user>:<pass>@cluster.xxxxx.mongodb.net/marketplace

# Générer avec : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGER_CETTE_VALEUR_MINIMUM_64_CARACTERES_ALEATOIRES

# URL du frontend (CORS)
CLIENT_URL=http://localhost:3000
